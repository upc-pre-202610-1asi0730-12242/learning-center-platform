package "Shared Bounded Context" {
    package "Domain" {
        interface IBaseRepository<TEntity> {
            +AddAsync(TEntity entity, CancellationToken cancellationToken): Task
            +FindByIdAsync(int id, CancellationToken cancellationToken): Task<TEntity?>
            +Update(TEntity entity): void
            +Remove(TEntity entity): void
            +ListAsync(CancellationToken cancellationToken): Task<IEnumerable<TEntity>>
        }

        interface IUnitOfWork {
            +CompleteAsync(CancellationToken cancellationToken): Task
        }

        interface IEvent {
        }

        class Result<T> {
            +IsSuccess: bool
            +IsFailure: bool
            +Value: T?
            +Message: string
            +Error: Enum?
            +Success(T value): Result<T>
            +Failure(Enum error, string message): Result<T>
        }

        class Result {
            +IsSuccess: bool
            +IsFailure: bool
            +Message: string
            +Error: Enum?
            +Success(): Result
            +Failure(Enum error, string message): Result
        }
    }

    package "Infrastructure" {
        class AppDbContext {
            +AppDbContext(DbContextOptions<AppDbContext> options)
            +SaveChangesAsync(CancellationToken cancellationToken): Task<int>
        }

        class BaseRepository<TEntity> implements IBaseRepository<TEntity> {
            +BaseRepository(AppDbContext context)
            +AddAsync(TEntity entity, CancellationToken cancellationToken): Task
            +FindByIdAsync(int id, CancellationToken cancellationToken): Task<TEntity?>
            +Update(TEntity entity): void
            +Remove(TEntity entity): void
            +ListAsync(CancellationToken cancellationToken): Task<IEnumerable<TEntity>>
        }

        class UnitOfWork implements IUnitOfWork {
            +UnitOfWork(AppDbContext context)
            +CompleteAsync(CancellationToken cancellationToken): Task
        }
    }

    package "Interfaces" {
        class ProblemDetailsFactory {
            +ProblemDetailsFactory(IStringLocalizer<ErrorMessages> errorLocalizer, IStringLocalizer<Commons> commonLocalizer, Microsoft.AspNetCore.Mvc.Infrastructure.ProblemDetailsFactory aspNetCoreProblemDetailsFactory)
            +CreateProblemDetails(ControllerBase controller, int statusCode, Enum? errorEnum, string detailMessage): IActionResult
            +CreateProblemDetails(ControllerBase controller, int statusCode, string titleKey, string detailKey, params object[] detailArgs): IActionResult
        }
    }
}

