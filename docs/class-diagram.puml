        class CategoriesController {
            +CategoriesController(ICategoryCommandService categoryCommandService, ICategoryQueryService categoryQueryService, IStringLocalizer<ErrorMessages> errorLocalizer, ProblemDetailsFactory problemDetailsFactory)
