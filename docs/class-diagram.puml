            +Username: string
            +PasswordHash: string
            +UpdateUsername(string username): User
            +UpdatePasswordHash(string passwordHash): User
        }

        interface IUserCommandService {
            +Handle(SignInCommand command, CancellationToken cancellationToken): Task<Result<(User user, string token)>>
            +Handle(SignUpCommand command, CancellationToken cancellationToken): Task<Result>
