    }

    package "Interfaces" {
        class TutorialsController {
            +TutorialsController(ITutorialCommandService tutorialCommandService, ITutorialQueryService tutorialQueryService, IStringLocalizer<ErrorMessages> errorLocalizer, ProblemDetailsFactory problemDetailsFactory)
