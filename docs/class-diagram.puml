@startuml Class Diagram - Publishing, IAM, Shared Bounded Contexts

package "Publishing Bounded Context" {
    package "Domain" {
        class Tutorial <<Aggregate>> {
            +Tutorial(string title, string summary, int categoryId)
            +Id: int
            +Title: string
            +Summary: string
            +CategoryId: int
            +Category: Category?
            +Assets: ICollection<Asset>
            +Status: EPublishingStatus
            +Readable: bool
            +Viewable: bool
            +HasReadableAssets: bool
            +HasViewableAssets: bool
            +CreatedDate: DateTimeOffset?
            +UpdatedDate: DateTimeOffset?
        }

        class Category <<Entity>> {
            +Category(string name)
            +Id: int
            +Name: string
        }

        class Asset <<Entity>> {
            +Asset(EAssetType type)
            +Id: int
            +AssetIdentifier: AcmeAssetIdentifier
            +Status: EPublishingStatus
            +Type: EAssetType
            +Readable: bool
            +Viewable: bool
            +SendToEdit(): void
            +SendToApproval(): void
            +ApproveAndLock(): void
            +Reject(): void
            +ReturnToEdit(): void
            +GetContent(): object
        }

        class VideoAsset extends Asset <<Entity>> {
            +VideoAsset(string videoUrl)
            +VideoUri: Uri?
            +Readable: bool = false
            +Viewable: bool = true
        }

        class ImageAsset extends Asset <<Entity>> {
            +ImageAsset()
            +ImageUri: Uri?
            +Readable: bool = false
            +Viewable: bool = true
        }

        class ReadableContentAsset extends Asset <<Entity>> {
            +ReadableContentAsset()
            +Readable: bool = true
            +Viewable: bool = false
        }

        enum EPublishingStatus {
            Draft
            ReadyToEdit
            ReadyToApproval
            ApprovedAndLocked
        }

        interface ITutorialQueryService {
            +Handle(GetTutorialByIdQuery query, CancellationToken cancellationToken): Task<Tutorial?>
            +Handle(GetAllTutorialsQuery query, CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
            +Handle(GetAllTutorialsByCategoryIdQuery query, CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
        }

        interface ITutorialCommandService {
            +Handle(AddVideoAssetToTutorialCommand command, CancellationToken cancellationToken): Task<Result<Tutorial>>
            +Handle(CreateTutorialCommand command, CancellationToken cancellationToken): Task<Result<Tutorial>>
        }

        interface ICategoryQueryService {
            +Handle(GetCategoryByIdQuery query, CancellationToken cancellationToken): Task<Category?>
            +Handle(GetAllCategoriesQuery query, CancellationToken cancellationToken): Task<IEnumerable<Category>>
        }

        interface ICategoryCommandService {
            +Handle(CreateCategoryCommand command, CancellationToken cancellationToken): Task<Result<Category>>
        }

        interface ITutorialRepository extends IBaseRepository<Tutorial> {
            +FindByCategoryIdAsync(int categoryId, CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
            +ExistsByTitleAsync(string title, CancellationToken cancellationToken): Task<bool>
        }

        interface ICategoryRepository extends IBaseRepository<Category> {
        }
    }

    package "Application" {
        class TutorialCommandService implements ITutorialCommandService {
            +TutorialCommandService(ITutorialRepository tutorialRepository, ICategoryRepository categoryRepository, IUnitOfWork unitOfWork, IStringLocalizer<ErrorMessages> localizer)
            +Handle(AddVideoAssetToTutorialCommand command, CancellationToken cancellationToken): Task<Result<Tutorial>>
            +Handle(CreateTutorialCommand command, CancellationToken cancellationToken): Task<Result<Tutorial>>
        }

        class TutorialQueryService implements ITutorialQueryService {
            +TutorialQueryService(ITutorialRepository tutorialRepository)
            +Handle(GetTutorialByIdQuery query, CancellationToken cancellationToken): Task<Tutorial?>
            +Handle(GetAllTutorialsQuery query, CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
            +Handle(GetAllTutorialsByCategoryIdQuery query, CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
        }

        class CategoryCommandService implements ICategoryCommandService {
            +CategoryCommandService(ICategoryRepository categoryRepository, IUnitOfWork unitOfWork, IMediator domainEventPublisher, IStringLocalizer<ErrorMessages> localizer)
            +Handle(CreateCategoryCommand command, CancellationToken cancellationToken): Task<Result<Category>>
        }

        class CategoryQueryService implements ICategoryQueryService {
            +CategoryQueryService(ICategoryRepository categoryRepository)
            +Handle(GetCategoryByIdQuery query, CancellationToken cancellationToken): Task<Category?>
            +Handle(GetAllCategoriesQuery query, CancellationToken cancellationToken): Task<IEnumerable<Category>>
        }
    }

    package "Infrastructure" {
        class TutorialRepository implements ITutorialRepository {
            +TutorialRepository(AppDbContext context)
            +AddAsync(Tutorial entity, CancellationToken cancellationToken): Task
            +FindByIdAsync(int id, CancellationToken cancellationToken): Task<Tutorial?>
            +Update(Tutorial entity): void
            +Remove(Tutorial entity): void
            +ListAsync(CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
            +FindByCategoryIdAsync(int categoryId, CancellationToken cancellationToken): Task<IEnumerable<Tutorial>>
            +ExistsByTitleAsync(string title, CancellationToken cancellationToken): Task<bool>
        }

        class CategoryRepository implements ICategoryRepository {
            +CategoryRepository(AppDbContext context)
            +AddAsync(Category entity, CancellationToken cancellationToken): Task
            +FindByIdAsync(int id, CancellationToken cancellationToken): Task<Category?>
            +Update(Category entity): void
            +Remove(Category entity): void
            +ListAsync(CancellationToken cancellationToken): Task<IEnumerable<Category>>
