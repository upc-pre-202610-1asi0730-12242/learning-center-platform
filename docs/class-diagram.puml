    TutorialRepository ..|> ITutorialRepository : implements
    CategoryRepository ..|> ICategoryRepository : implements
}

package "IAM Bounded Context" {
    package "Domain" {
        class User <<Aggregate>> {
            +User(string username, string passwordHash)
